# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # PostgreSQL connection string (postgresql://user:pass@host:port/db)
SECRETS_KEY=              # 32+ random characters used to encrypt API credentials at rest

# ── Server ──────────────────────────────────────────────────────
PORT=3000                 # HTTP server port (default: 3000)
